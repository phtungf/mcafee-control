#!/bin/bash

# McAfee Control Script
# Usage: mcafee {stop|start|status}

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

LAUNCH_DAEMONS=(
    "/Library/LaunchDaemons/com.mcafee.CmacPatch.plist"
    "/Library/LaunchDaemons/com.mcafee.PeriodicScan.plist"
    "/Library/LaunchDaemons/com.mcafee.cspd.plist"
    "/Library/LaunchDaemons/com.mcafee.datupdate.plist"
    "/Library/LaunchDaemons/com.mcafee.genutility.plist"
    "/Library/LaunchDaemons/com.mcafee.mac.cloudsdkdaemon.plist"
    "/Library/LaunchDaemons/com.mcafee.productupdate.plist"
    "/Library/LaunchDaemons/com.mcafee.ssm.ScanFactory.plist"
    "/Library/LaunchDaemons/com.mcafee.ssm.ScanManager.plist"
    "/Library/LaunchDaemons/com.mcafee.virusscan.fmpd.plist"
)

LAUNCH_AGENTS=(
    "/Library/LaunchAgents/com.mcafee.macvpn.plist"
    "/Library/LaunchAgents/com.mcafee.menulet.plist"
    "/Library/LaunchAgents/com.mcafee.registerfinderextension.plist"
    "/Library/LaunchAgents/com.mcafee.reporter.plist"
    "/Library/LaunchAgents/com.mcafee.uninstall.SystemExtension.plist"
)

check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}Root required: sudo mcafee $1${NC}"
        exit 1
    fi
}

# Kill processes matching pattern, but never kill self or any ancestor
# (script PID, parent shell, sudo, install.sh, terminal, etc.).
safe_pkill() {
    local signal="$1" pattern="$2" pid pids skip p
    pids=$(pgrep -f "$pattern" 2>/dev/null) || true
    [ -z "$pids" ] && return 0

    skip=" $$ $PPID "
    p="$PPID"
    while [ -n "$p" ] && [ "$p" != "0" ] && [ "$p" != "1" ]; do
        p=$(ps -o ppid= -p "$p" 2>/dev/null | tr -d ' ')
        [ -z "$p" ] && break
        skip="$skip$p "
    done

    for pid in $pids; do
        case "$skip" in
            *" $pid "*) continue ;;
        esac
        kill "$signal" "$pid" 2>/dev/null || true
    done
}

stop_mcafee() {
    check_root "stop"
    echo -e "${YELLOW}Stopping McAfee...${NC}"

    for plist in "${LAUNCH_DAEMONS[@]}"; do
        if [ -f "$plist" ]; then
            launchctl bootout system "$plist" 2>/dev/null
        fi
    done

    local uid
    uid=$(id -u "${SUDO_USER:-$USER}")
    for plist in "${LAUNCH_AGENTS[@]}"; do
        if [ -f "$plist" ]; then
            launchctl bootout "gui/$uid" "$plist" 2>/dev/null
        fi
    done

    killall VShieldScanner VShieldScanManager VShieldService \
            StatefulFirewall fmpd cspd CloudSDKDaemon \
            "McAfee Health Monitor" "com.mcafee.CMF.networkextension" \
            SafeConnect Menulet "McAfee Reporter" \
            MenuletFinderExtension 2>/dev/null

    sleep 1

    safe_pkill -9 "/usr/local/McAfee/"
    safe_pkill -9 "com.mcafee"
    safe_pkill -9 "McAfee"

    local sysext_id
    sysext_id=$(systemextensionsctl list 2>/dev/null | grep -i mcafee | awk '{print $NF}' | head -1)
    if [ -n "$sysext_id" ]; then
        systemextensionsctl uninstall operator "$sysext_id" 2>/dev/null
    fi

    defaults write /Library/Preferences/com.mcafee.CMF.networkextension enabled -bool false 2>/dev/null

    sleep 2

    safe_pkill -9 "mcafee"

    sleep 1
    local count
    count=$(ps aux | grep -i mcafee | grep -v -E "grep|mcafee stop|mcafee start|sudo mcafee|/bin/bash.*mcafee|/usr/local/bin/mcafee" | wc -l | tr -d ' ')
    if [ "$count" -eq 0 ]; then
        echo -e "${GREEN}McAfee fully stopped.${NC}"
    else
        echo -e "${RED}$count process(es) still running:${NC}"
        ps aux | grep -i mcafee | grep -v -E "grep|mcafee stop|sudo mcafee|/bin/bash.*mcafee"
    fi
}

start_mcafee() {
    check_root "start"
    echo -e "${YELLOW}Starting McAfee...${NC}"

    for plist in "${LAUNCH_DAEMONS[@]}"; do
        if [ -f "$plist" ]; then
            launchctl bootstrap system "$plist" 2>/dev/null
        fi
    done

    local uid
    uid=$(id -u "${SUDO_USER:-$USER}")
    for plist in "${LAUNCH_AGENTS[@]}"; do
        if [ -f "$plist" ]; then
            launchctl bootstrap "gui/$uid" "$plist" 2>/dev/null
        fi
    done

    sleep 2
    local count
    count=$(pgrep -f -i mcafee 2>/dev/null | wc -l | tr -d ' ')
    echo -e "${GREEN}McAfee started. $count process(es) running.${NC}"
}

status_mcafee() {
    local procs
    procs=$(ps aux | grep -i mcafee | grep -v -E "grep|/bin/bash|/usr/local/bin/mcafee|sudo mcafee|mcafee status")
    local count
    count=$(echo "$procs" | grep -c . 2>/dev/null)
    if [ -z "$procs" ] || [ "$count" -eq 0 ]; then
        echo -e "${RED}McAfee: STOPPED (no processes)${NC}"
    else
        echo -e "${GREEN}McAfee: RUNNING ($count process(es))${NC}"
        echo "$procs" | awk '{printf "  PID %-8s CPU %-6s %s\n", $2, $3, $11}'
    fi
}

case "$1" in
    stop)
        stop_mcafee
        ;;
    start)
        start_mcafee
        ;;
    status)
        status_mcafee
        ;;
    *)
        echo "Usage: mcafee {stop|start|status}"
        echo ""
        echo "  sudo mcafee stop    - Fully stop McAfee"
        echo "  sudo mcafee start   - Start McAfee back up"
        echo "  mcafee status       - Show current status"
        exit 1
        ;;
esac
